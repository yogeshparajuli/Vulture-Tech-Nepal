# Postgres connection strings from Neon (or any Postgres host).
# Neon gives you both a pooled URL (use for DATABASE_URL) and a direct URL (use for DIRECT_URL, needed for migrations).
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"
DIRECT_URL="postgresql://user:password@host/dbname?sslmode=require"

# NextAuth — generate your own with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AUTH_SECRET=""
NEXTAUTH_URL="http://localhost:3000"

# Stripe (test mode). Leave blank to fall back to Cash on Delivery checkout.
STRIPE_SECRET_KEY=""
STRIPE_PUBLISHABLE_KEY=""
STRIPE_WEBHOOK_SECRET=""

NEXT_PUBLIC_BASE_URL="http://localhost:3000"
